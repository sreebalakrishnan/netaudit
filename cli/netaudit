#!/bin/bash
# NetAudit CLI shim. A py2app bundle can't be launched through a symlink (its
# bootstrap resolves Info.plist/Python relative to the executable's path), so
# Homebrew's `binary` symlink and install.sh point at THIS script instead. It
# follows the symlink chain back to itself inside the .app, then execs the real
# bundle executable by its true path — which py2app is happy with.
target="$0"
while [ -L "$target" ]; do
  link="$(readlink "$target")"
  case "$link" in
    /*) target="$link" ;;
    *)  target="$(dirname "$target")/$link" ;;
  esac
done
here="$(cd "$(dirname "$target")" && pwd)"
exec "$here/../MacOS/NetAudit" "$@"
